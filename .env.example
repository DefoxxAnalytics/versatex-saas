# =============================================================================
# SECURITY WARNING: Change ALL default values before first run!
# =============================================================================

# Django Settings
# IMPORTANT: Generate a new SECRET_KEY for production using:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=MUST_CHANGE_secret_key_before_use
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Admin URL (leave empty for dynamic random URL, or set custom path)
# When empty, a random URL is generated on each startup and logged
# Example: ADMIN_URL=secure-admin-panel-8f3a/
ADMIN_URL=

# Database
# SECURITY: You MUST change DB_PASSWORD before running!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_NAME=analytics_db
DB_USER=analytics_user
DB_PASSWORD=MUST_CHANGE_db_password_before_use
DB_HOST=db
DB_PORT=5432

# CORS (add your production domain)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# CSRF (add your production domain)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email (Console for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@analytics.com

# Redis (for Celery and caching)
# SECURITY: You MUST change REDIS_PASSWORD before running!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=MUST_CHANGE_redis_password_before_use

# Celery (uses Redis with authentication)
# Note: docker-compose.yml automatically includes the Redis password
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000/api
VITE_APP_TITLE=Analytics Dashboard
VITE_APP_LOGO=/vtx_logo2.png

# Encryption Key for sensitive fields (django-encrypted-model-fields)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-encryption-key-here

# LLM provider keys (optional). When set, AI-insights features use the provider
# keyed here if the user has not configured their own. Without any key, Django
# serves deterministic-only insights.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Daily LLM cost-digest webhook (optional). When set, the send_llm_cost_digest
# Celery Beat task POSTs a plain-text summary every day at 06:00 UTC. Compatible
# with ntfy.sh (https://ntfy.sh/<your-topic>), Slack incoming webhooks, and
# Teams webhooks. Empty = digest task still runs + logs, just no outbound POST.
# COST_ALERT_WEBHOOK_URL=

# pgvector IVFFlat index tuning (analytics embeddings)
# Default 100 lists; Postgres docs recommend sqrt(rows). Tune after
# `pg_stat_user_indexes` shows the hit ratio.
# PGVECTOR_IVFFLAT_LISTS=100

# HSTS (production only; both default False — safe for first deploy).
# Flip to True after 1 week of prod validation. includeSubDomains pins every
# *.versatexanalytics.com subdomain to HTTPS for max-age (1 year) irreversibly.
# HSTS_INCLUDE_SUBDOMAINS=False
# HSTS_PRELOAD=False

# =============================================================================
# Cloudflare R2 Media Storage (optional)
# =============================================================================
# When USE_R2_MEDIA=True, Django writes all user media uploads (org logos,
# generated PDF reports, etc.) directly to Cloudflare R2 instead of the VPS
# disk. Requires creating a versatex-media bucket in R2 and a scoped API
# token (see docs/deployment/BACKUPS-AND-MEDIA.md for setup).
# Disabled by default — media lives on VPS disk, synced to R2 nightly by
# scripts/backup-media.sh.
USE_R2_MEDIA=False
# R2_MEDIA_BUCKET=versatex-media
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# =============================================================================
# PRODUCTION SECURITY CHECKLIST
# =============================================================================
# Before deploying to production, ensure you have:
# 1. Generated a new SECRET_KEY (see command above)
# 2. Set DEBUG=False
# 3. Changed ADMIN_URL to a non-standard path
# 4. Set strong passwords for DB_PASSWORD and REDIS_PASSWORD
# 5. Updated ALLOWED_HOSTS with your production domain(s)
# 6. Updated CORS_ALLOWED_ORIGINS with HTTPS production URLs
# 7. Updated CSRF_TRUSTED_ORIGINS with HTTPS production URLs
# 8. Generated FIELD_ENCRYPTION_KEY if using field encryption
# 9. Configured proper email settings for notifications
# 10. Use docker-compose.prod.yml for production deployment
