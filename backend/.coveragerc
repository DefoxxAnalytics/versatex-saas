[run]
source = apps
branch = False
omit =
    # Auto-generated code
    */migrations/*
    */__pycache__/*
    # Test files shouldn't count toward app coverage
    */tests/*
    */test_*.py
    */conftest.py
    # Management commands: scripts, not app logic
    */management/commands/*
    # Django boilerplate
    */apps.py
    */admin.py
    # Settings/config modules
    config/*
    manage.py

[report]
# Fail the run if overall line coverage is below this threshold.
# v3.1 Phase 3 (XC-M3): ratcheted from 55 → 62 after measuring 64.73%
# baseline (May 2026, post-Phase-1 + Phase-2 fixes). The 2.7-point
# buffer below the actual reading absorbs day-to-day variance from
# Windows-flaky tests + skipped Postgres-only tests; routine CI runs
# stay green while a real regression > ~3 points fails fast.
# Ratchet up by ~5 points whenever the floor + buffer + new tests
# leaves another 5-point gap. NEVER lower this — drop only via an
# intentional revert with documented justification.
fail_under = 62
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise NotImplementedError
    if TYPE_CHECKING:
    if __name__ == .__main__.:

[html]
directory = htmlcov
